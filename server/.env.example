# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017/healthhub
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/healthhub
MONGODB_URI=mongodb://localhost:27017/healthhub

# JWT Authentication
# Generate a strong random secret key (at least 32 characters)
JWT_SECRET=your_super_secret_jwt_key_change_this_to_random_string

# Groq AI Configuration
# Get your API key from: https://console.groq.com
GROQ_API_KEY=

# Google Maps API (Optional)
# Get your API key from: https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
